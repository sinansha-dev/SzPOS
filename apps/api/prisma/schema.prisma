// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id        String   @id
  sku       String   @unique
  name      String
  price     Decimal  @db.Decimal(12, 2)
  taxRate   Decimal  @default(0.05) @db.Decimal(5, 4) @map("tax_rate")
  stock     Int      @default(0)
  createdAt DateTime @default(now()) @db.Timestamptz() @map("created_at")
  updatedAt DateTime @updatedAt @db.Timestamptz() @map("updated_at")

  @@map("products")
}

model User {
  id        String   @id
  name      String
  username  String   @unique
  role      Role
  status    Status
  createdAt DateTime @default(now()) @db.Timestamptz() @map("created_at")
  updatedAt DateTime @updatedAt @db.Timestamptz() @map("updated_at")

  @@map("users")
}

model Sale {
  id        String   @id
  payload   Json
  createdAt DateTime @default(now()) @db.Timestamptz() @map("created_at")

  @@map("sales")
}

model PurchaseOrder {
  id        String   @id
  payload   Json
  createdAt DateTime @default(now()) @db.Timestamptz() @map("created_at")

  @@map("purchase_orders")
}

model Return {
  id        String   @id
  payload   Json
  createdAt DateTime @default(now()) @db.Timestamptz() @map("created_at")

  @@map("returns")
}

enum Role {
  admin
  cashier
  manager
}

enum Status {
  active
  inactive
}
