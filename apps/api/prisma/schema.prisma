generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id               String   @id
  businessName     String   @map("business_name")
  email            String   @unique
  subscriptionPlan String   @default("starter") @map("subscription_plan")
  createdAt        DateTime @default(now()) @db.Timestamptz() @map("created_at")
  users            User[]

  @@map("accounts")
}

model Product {
  id        String   @id
  accountId String   @map("account_id")
  sku       String
  name      String
  price     Decimal  @db.Decimal(12, 2)
  taxRate   Decimal  @default(0.05) @db.Decimal(5, 4) @map("tax_rate")
  stock     Int      @default(0)
  createdAt DateTime @default(now()) @db.Timestamptz() @map("created_at")
  updatedAt DateTime @updatedAt @db.Timestamptz() @map("updated_at")

  @@unique([accountId, sku])
  @@map("products")
}

model User {
  id             String   @id
  accountId      String   @map("account_id")
  name           String
  email          String
  username       String
  passwordHash   String   @map("password_hash")
  role           Role
  status         Status
  resetToken     String?  @map("reset_token")
  resetTokenExp  DateTime? @db.Timestamptz() @map("reset_token_exp")
  createdAt      DateTime @default(now()) @db.Timestamptz() @map("created_at")
  updatedAt      DateTime @updatedAt @db.Timestamptz() @map("updated_at")
  account        Account  @relation(fields: [accountId], references: [id])

  @@unique([accountId, username])
  @@unique([accountId, email])
  @@map("users")
}

model Sale {
  id        String   @id
  accountId String   @map("account_id")
  payload   Json
  createdAt DateTime @default(now()) @db.Timestamptz() @map("created_at")

  @@map("sales")
}

model PurchaseOrder {
  id        String   @id
  accountId String   @map("account_id")
  payload   Json
  createdAt DateTime @default(now()) @db.Timestamptz() @map("created_at")

  @@map("purchase_orders")
}

model Return {
  id        String   @id
  accountId String   @map("account_id")
  payload   Json
  createdAt DateTime @default(now()) @db.Timestamptz() @map("created_at")

  @@map("returns")
}

enum Role {
  OWNER
  ADMIN
  CASHIER
  KITCHEN
  VIEWER
}

enum Status {
  ACTIVE
  DISABLED
}
